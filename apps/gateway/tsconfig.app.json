{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "types": ["node"],
    // rootDir intentionally NOT set: webpack pulls in workspace library
    // source (e.g. @org/tenant-registry from libs/tenant-registry/src/),
    // and `rootDir: "src"` would reject anything outside apps/gateway/src.
    // Compilation scope is still constrained by `include` below.
    "tsBuildInfoFile": "dist/tsconfig.app.tsbuildinfo",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "target": "es2021"
  },
  "include": ["src/**/*.ts"],
  "exclude": [
    "jest.config.ts",
    "jest.config.cts",
    "src/**/*.spec.ts",
    "src/**/*.test.ts"
  ],
  "references": [
    {
      "path": "../../libs/auth-keycloak/tsconfig.lib.json"
    },
    {
      "path": "../../libs/tenant-registry/tsconfig.lib.json"
    }
  ]
}
