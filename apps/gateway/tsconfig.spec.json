{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./out-tsc/jest",
    "module": "commonjs",
    "moduleResolution": "node10",
    "customConditions": null,
    "types": ["jest", "node"],
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "target": "es2021"
  },
  "include": [
    "jest.config.ts",
    "jest.config.cts",
    "src/**/*.ts",
    "src/**/*.d.ts",
    "test/**/*.ts"
  ]
}
