// Gateway service schema.
//
// Phase 1.0 carries only a placeholder HealthCheck table to exercise the
// migration loop. Real domain models begin in milestones 1.2 (tenants) and
// 1.3 (students). Tenant-aware tables in later milestones will gain
// `tenantId UUID NOT NULL` plus RLS policies in their migrations.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

// Prisma 7+ moved the connection URL out of schema.prisma.
// See ../../prisma.config.ts at the workspace root for `datasource.url`.
datasource db {
  provider = "postgresql"
}

// The Tenant table moved to tenant-service (sms_control DB) in milestone 1.2.
// gateway no longer owns Tenant rows — tenantId on tenant-scoped tables is
// a "logical reference" to a row in another database. There is NO foreign
// key here. The tenant-registry client (@org/tenant-registry) validates the
// ID against tenant-service before any operation runs.

model HealthCheck {
  id        String    @id @default(uuid()) @db.Uuid
  tenantId  String    @db.Uuid
  checkedAt DateTime  @default(now())
  status    String    @default("ok")
  deletedAt DateTime?

  @@index([tenantId])
  @@map("health_check")
}
