# Copy to .env.local (gitignored) and edit for your local environment.
# Never commit actual credentials, even local-only ones — that habit prevents accidents later.

# === Database (consumed by Postgres container AND by Prisma) ===
POSTGRES_USER=sms_app
POSTGRES_PASSWORD=change_me_locally
POSTGRES_DB=sms_dev

# Connection string for Prisma (host = localhost when running app outside Docker;
# host = postgres when running app inside the same Compose network).
# Note: host port is 5433 (not 5432) so we don't collide with a native
# Postgres on the dev machine. Container internally still listens on 5432.
DATABASE_URL=postgresql://sms_app:change_me_locally@localhost:5433/sms_dev?schema=public

# === Telemetry ===
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=gateway
OTEL_RESOURCE_ATTRIBUTES=service.namespace=sms,deployment.environment=local

# === Application ===
PORT=3000
NODE_ENV=development
