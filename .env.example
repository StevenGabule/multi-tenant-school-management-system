# Copy to .env.local (gitignored) and edit for your local environment.
# Never commit actual credentials, even local-only ones — that habit prevents accidents later.

# === Database ===
# POSTGRES_USER (sms_app) is the superuser created by the postgres image.
# Migrations run as this role (DDL needs the privilege). Application traffic
# does NOT — see DATABASE_URL below.
POSTGRES_USER=sms_app
POSTGRES_PASSWORD=change_me_locally
POSTGRES_DB=sms_dev

# DATABASE_URL — runtime app connection. Through PgBouncer (host 6432) in
# transaction mode. ?pgbouncer=true disables Prisma's prepared-statement
# cache (transaction-mode pooling reuses server connections, so prepared
# statements would leak across clients). Uses app_user (non-superuser,
# non-BYPASSRLS); RLS enforces tenant isolation.
DATABASE_URL=postgresql://app_user:app_user_local_dev_pwd@localhost:6432/sms_dev?schema=public&pgbouncer=true

# DATABASE_MIGRATION_URL — used ONLY by `prisma migrate ...` commands.
# DIRECT to Postgres on host 5433, bypassing PgBouncer. Transaction-mode
# pooling breaks the long-running DDL transactions Prisma migrate uses.
DATABASE_MIGRATION_URL=postgresql://sms_app:change_me_locally@localhost:5433/sms_dev?schema=public

# === tenant-service / control plane (milestone 1.2) ===
# Separate database on the same Postgres cluster. tenant-service holds
# the registry (tenants, plans, feature flags) — NOT under RLS.
CONTROL_PLANE_DATABASE_URL=postgresql://sms_app:change_me_locally@localhost:5433/sms_control?schema=public
CONTROL_PLANE_MIGRATION_URL=postgresql://sms_app:change_me_locally@localhost:5433/sms_control?schema=public
TENANT_SERVICE_PORT=3001
TENANT_SERVICE_BASE_URL=http://localhost:3001

# === sis-service (milestone 1.3) ===
# Tenant-scoped data plane (Student/Guardian aggregates). Same Postgres
# cluster, separate logical database.
# NOTE: bypasses PgBouncer (direct to Postgres). Our compose PgBouncer is
# configured for sms_dev only; multi-DB PgBouncer config is a Phase 2 task.
# Application code is identical either way (SET LOCAL pattern works under
# both direct + transaction-mode pooling).
SIS_DATABASE_URL=postgresql://app_user:app_user_local_dev_pwd@localhost:5433/sms_sis?schema=public
SIS_MIGRATION_URL=postgresql://sms_app:change_me_locally@localhost:5433/sms_sis?schema=public
SIS_SERVICE_PORT=3002
SIS_SERVICE_BASE_URL=http://localhost:3002

# OutboxRelay connection — runs as sms_app (BYPASSRLS) so it can drain
# the outbox queue across all tenants. Bypasses PgBouncer because
# LISTEN/NOTIFY needs a long-lived session connection that
# transaction-mode pooling breaks.
SIS_OUTBOX_URL=postgresql://sms_app:change_me_locally@localhost:5433/sms_sis?schema=public
SIS_OUTBOX_CHANNEL=sms.sis.outbox

# === academic-service (milestone 1.4) ===
# Tenant-scoped data plane for course/section/enrollment-slot data.
# Same Postgres cluster, separate logical database.
ACADEMIC_DATABASE_URL=postgresql://app_user:app_user_local_dev_pwd@localhost:5433/sms_academic?schema=public
ACADEMIC_MIGRATION_URL=postgresql://sms_app:change_me_locally@localhost:5433/sms_academic?schema=public
# Long-lived LISTEN connection for the StudentEventsConsumer. Connects to
# sis-service's database (the producer's DB) as a read-only-ish role
# (sms_app for now; Phase 2 may add a dedicated subscriber role).
ACADEMIC_LISTEN_URL=postgresql://sms_app:change_me_locally@localhost:5433/sms_sis?schema=public
ACADEMIC_SERVICE_PORT=3003
ACADEMIC_SERVICE_BASE_URL=http://localhost:3003

# === enrollment-service (milestone 1.5 — saga orchestrator) ===
# Owns sms_enrollment for SagaInstance / SagaStep state machine rows.
# These are tenant-scoped under RLS like every other domain table.
ENROLLMENT_DATABASE_URL=postgresql://app_user:app_user_local_dev_pwd@localhost:5433/sms_enrollment?schema=public
ENROLLMENT_MIGRATION_URL=postgresql://sms_app:change_me_locally@localhost:5433/sms_enrollment?schema=public
# Saga executor uses sms_app (BYPASSRLS) so it can scan ALL tenants'
# sagas. Bypasses PgBouncer because FOR UPDATE SKIP LOCKED transactions
# may run longer than transaction-mode pooler limits.
ENROLLMENT_EXECUTOR_URL=postgresql://sms_app:change_me_locally@localhost:5433/sms_enrollment?schema=public
ENROLLMENT_SERVICE_PORT=3004
ENROLLMENT_SERVICE_BASE_URL=http://localhost:3004

# === Redis (cache layer + pub/sub for invalidation) ===
REDIS_URL=redis://localhost:6380
REDIS_INVALIDATION_CHANNEL=sms:tenant:invalidated

# === Auth (hand-rolled JWT for milestones 1.1–1.5; replaced by Keycloak in 1.6) ===
# Use `openssl rand -base64 32` for a real secret. NEVER commit the actual
# value — only the placeholder belongs in this example file.
# Kept in 1.6+ so old tests that mint dev tokens via /api/dev/token still work.
JWT_SECRET=replace_me_with_openssl_rand_base64_32

# === Keycloak (milestone 1.6+) ===
# OIDC discovery: <issuer>/.well-known/openid-configuration
KEYCLOAK_ISSUER_URL=http://localhost:8080/realms/sms-platform
# JWT `aud` claim that services validate. Tokens minted for the gateway
# client carry aud=gateway.
KEYCLOAK_AUDIENCE=gateway
# Confidential client for service-to-service token issuance via the
# client_credentials grant. Replaces JWT_SECRET-forging in the
# enrollment saga's CrossServiceClient.
KEYCLOAK_SERVICES_CLIENT_ID=services
KEYCLOAK_SERVICES_CLIENT_SECRET=replace_me_after_running_infra/keycloak/bootstrap.sh
# Public client for browser auth (PKCE) and dev password-grant testing.
KEYCLOAK_GATEWAY_CLIENT_ID=gateway

# === Telemetry ===
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=gateway
OTEL_RESOURCE_ATTRIBUTES=service.namespace=sms,deployment.environment=local

# === Application ===
PORT=3000
NODE_ENV=development
