    "prisma:gateway:generate": "dotenv -e .env.local -- prisma generate --schema apps/gateway/prisma/schema.prisma",
    "prisma:gateway:studio": "dotenv -e .env.local -- prisma studio --schema apps/gateway/prisma/schema.prisma"
  },
  "private": true,
  "pnpm": {
