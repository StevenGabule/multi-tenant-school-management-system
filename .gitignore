# Dependencies
node_modules/
.pnpm-store/

# Build artifacts
dist/
build/
out/
tmp/
*.tsbuildinfo

# Nx
.nx/cache
.nx/workspace-data

# Test artifacts
coverage/
.nyc_output/

# Logs
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*

# Environments — never commit credentials, even local ones
.env
.env.local
.env.*.local
.env.development.local
.env.production.local
!.env.example

# Local overrides
docker-compose.override.yml

# Persistent local state
.pgdata/
.local-data/

# Prisma
prisma/.env

# Editor / OS
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# Generated Prisma client output (when configured outside node_modules)
**/generated/prisma/

# Kubernetes secret manifests — never commit
infra/k8s/**/secret.yaml
infra/k8s/**/secrets.yaml
