# pnpm config — be strict about what we install.
#
# auto-install-peers=false: don't pull in peer dependencies that aren't
# explicitly listed. Our @prisma/client@7 declares `prisma` (40MB CLI),
# `@prisma/studio-core` (40MB UI), `react`, `react-dom`, `chart.js`, etc.
# as peers — none of which are needed at server runtime. Disabling this
# trims the production image dramatically.
auto-install-peers=false

# Strict peer warnings so we notice when a real peer is missing.
strict-peer-dependencies=false
