{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "type": "row",
      "title": "Platform health (RED, all services)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100
    },
    {
      "type": "stat",
      "title": "Request rate (req/s, all services)",
      "description": "Sum of all HTTP requests across all services. The first signal of 'is anything happening?' If this drops to zero with users active, the gateway is wedged.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(sms_traces_spanmetrics_calls_total{span_kind=\"SPAN_KIND_SERVER\"}[1m]))",
          "legendFormat": "req/s",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "yellow", "value": null },
              { "color": "green", "value": 0.01 }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 1 },
      "id": 1
    },
    {
      "type": "stat",
      "title": "Error rate (5xx, all services)",
      "description": "5xx errors per second. SLO budget burns when this > 0.1% of total request rate. Symptom-based alert: page on this, not on CPU.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(sms_traces_spanmetrics_calls_total{span_kind=\"SPAN_KIND_SERVER\",status_code=\"STATUS_CODE_ERROR\"}[1m]))",
          "legendFormat": "errors/s",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.05 },
              { "color": "red", "value": 0.5 }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 1 },
      "id": 2
    },
    {
      "type": "stat",
      "title": "p99 latency (all services)",
      "description": "99th percentile request duration. Latency SLO breach (>500ms) is a paging symptom — users feel slowness here directly.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(sms_traces_spanmetrics_latency_bucket{span_kind=\"SPAN_KIND_SERVER\"}[5m])))",
          "legendFormat": "p99",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.3 },
              { "color": "red", "value": 0.5 }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 1 },
      "id": 3
    },
    {
      "type": "stat",
      "title": "Active services (Tempo)",
      "description": "Services with at least one trace in the last 5 min. If this drops below the expected count, a service is silent — investigate.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "count(count by (service_name) (sms_traces_spanmetrics_calls_total))",
          "legendFormat": "services",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 4 },
              { "color": "green", "value": 6 }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 1 },
      "id": 4
    },
    {
      "type": "row",
      "title": "Per-service health",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 6 },
      "id": 101
    },
    {
      "type": "timeseries",
      "title": "Request rate by service",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (service_name) (rate(sms_traces_spanmetrics_calls_total{span_kind=\"SPAN_KIND_SERVER\"}[1m]))",
          "legendFormat": "{{service_name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "options": {
        "legend": { "showLegend": true, "displayMode": "table", "placement": "right" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 7 },
      "id": 5
    },
    {
      "type": "timeseries",
      "title": "Error rate by service (5xx)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (service_name) (rate(sms_traces_spanmetrics_calls_total{span_kind=\"SPAN_KIND_SERVER\",status_code=\"STATUS_CODE_ERROR\"}[1m]))",
          "legendFormat": "{{service_name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "options": {
        "legend": { "showLegend": true, "displayMode": "table", "placement": "right" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 7 },
      "id": 6
    },
    {
      "type": "timeseries",
      "title": "p95 latency by service",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (service_name, le) (rate(sms_traces_spanmetrics_latency_bucket{span_kind=\"SPAN_KIND_SERVER\"}[5m])))",
          "legendFormat": "{{service_name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } },
      "options": {
        "legend": { "showLegend": true, "displayMode": "table", "placement": "right" }
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 15 },
      "id": 7
    },
    {
      "type": "row",
      "title": "Tenant top-N (multi-tenant operability)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "id": 102
    },
    {
      "type": "table",
      "title": "Tenants by request rate (top 20)",
      "description": "The single most important panel for a multi-tenant platform. If one tenant suddenly bursts (10x typical), they may be impacting others. The first place to look when 'the platform feels slow' arrives.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "topk(20, sum by (tenant_id) (rate(sms_traces_spanmetrics_calls_total{tenant_id!=\"\"}[5m])))",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "filterable": true } }
      },
      "transformations": [
        { "id": "organize", "options": { "renameByName": { "Value": "req/s" } } }
      ],
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 24 },
      "id": 8
    },
    {
      "type": "table",
      "title": "Tenants by error rate (top 20)",
      "description": "Per-tenant 5xx rate. A tenant whose error rate jumps without others changing is the one being underserved — investigate that tenant first.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "topk(20, sum by (tenant_id) (rate(sms_traces_spanmetrics_calls_total{tenant_id!=\"\",status_code=\"STATUS_CODE_ERROR\"}[5m])))",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "filterable": true } }
      },
      "transformations": [
        { "id": "organize", "options": { "renameByName": { "Value": "errors/s" } } }
      ],
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 24 },
      "id": 9
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["sms", "platform"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "SMS — Platform overview",
  "uid": "sms-platform-overview",
  "version": 1,
  "weekStart": ""
